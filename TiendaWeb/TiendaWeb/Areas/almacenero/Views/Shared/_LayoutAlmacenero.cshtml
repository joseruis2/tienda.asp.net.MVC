@using System.Security.Claims
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Almacén</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />

    <link rel="stylesheet" href="~/css/almacenero/shared/layout.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @{
        var usuario = User.FindFirst("Nombres")?.Value ?? User.Identity?.Name ?? "Usuario";
        var rol = User.FindFirst(ClaimTypes.Role)?.Value ?? "";
        var iniciales = usuario.Length > 0 ? usuario[0].ToString().ToUpper() : "A";

        var currentCtrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
        var currentAct = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

        bool IsActive(string ctrl, string? act = null) =>
            currentCtrl.Equals(ctrl, StringComparison.OrdinalIgnoreCase) &&
            (act == null || currentAct.Equals(act, StringComparison.OrdinalIgnoreCase));
    }

    <nav id="sidebar">
        <div class="sidebar-brand">
            <div class="brand-icon"><i class="bi bi-boxes"></i></div>
            <span>Almacén</span>
        </div>
        <div class="sidebar-scroll">
            <div class="nav-section">Inventario</div>
            <ul class="list-unstyled mb-0">
                <li class="nav-item-alm">
                    <a asp-area="almacenero" asp-controller="Productos" asp-action="Index"
                       class="@(IsActive("Productos") ? "active" : "")">
                        <i class="bi bi-box-seam"></i> Productos / Stock
                    </a>
                </li>
                <!-- Agrega este item después del de Productos -->
                <li class="nav-item-alm">
                    <a asp-area="almacenero" asp-controller="Kardex" asp-action="Index"
                       class="@(IsActive("Kardex") ? "active" : "")">
                        <i class="bi bi-arrow-left-right"></i> Movimientos Kardex
                    </a>
                </li>
            </ul>

            <!-- Agrega ANTES del item de Productos -->
            <div class="nav-section">Principal</div>
            <ul class="list-unstyled mb-0">
                <li class="nav-item-alm">
                    <a asp-area="almacenero" asp-controller="Dashboard" asp-action="Index"
                       class="@(IsActive("Dashboard") ? "active" : "")">
                        <i class="bi bi-speedometer2"></i> Dashboard
                    </a>
                </li>
                <li class="nav-item-alm">
                    <a asp-area="almacenero" asp-controller="Compras" asp-action="Index"
                       class="@(IsActive("Compras") ? "active" : "")">
                        <i class="bi bi-truck"></i> Recepción de Compras
                    </a>
                </li>
            </ul>
           
        </div>
        <div class="sidebar-footer">
            <div class="user-info">
                <div class="avatar">@iniciales</div>
                <div>
                    <div class="user-name">@usuario</div>
                    <div class="user-rol">@rol</div>
                </div>
                <form asp-controller="Login" asp-action="Logout"
                      asp-area="" method="post" class="ms-auto">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-link p-0"
                            style="color:#6ee7b7" title="Cerrar sesión">
                        <i class="bi bi-box-arrow-right"></i>
                    </button>
                </form>
            </div>
        </div>
    </nav>

    <header id="topbar">
        <button class="btn btn-sidebar-toggle btn-sm btn-outline-secondary"
                onclick="document.getElementById('sidebar').classList.toggle('show')">
            <i class="bi bi-list"></i>
        </button>
        <span class="page-title">@(ViewData["Title"] ?? "Almacén")</span>
        <span class="text-muted small d-none d-md-inline">
            @DateTime.Now.ToString("ddd dd MMM yyyy")
        </span>
    </header>

    <main id="main-content">
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>