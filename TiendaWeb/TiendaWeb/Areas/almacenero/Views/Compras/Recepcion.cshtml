@model TiendaWeb.Areas.almacenero.ViewModel.RecepcionAlmaceneroViewModel
@{
    Layout = "~/Areas/almacenero/Views/Shared/_LayoutAlmacenero.cshtml";
    ViewData["Title"] = "Recepción de Mercadería";
}

<style>
    .rec-card {
        border: none;
        border-radius: 14px;
        box-shadow: 0 1px 6px rgba(0,0,0,.07);
    }

    .form-control {
        font-size: .875rem;
        background: #f8fafc;
        border-color: #e2e8f0;
    }

        .form-control:focus {
            border-color: #10b981;
            box-shadow: 0 0 0 3px rgba(16,185,129,.12);
            background: #fff;
        }

    .producto-row {
        transition: background .15s;
    }

        .producto-row:hover {
            background: #f0fdf4;
        }

    .stock-actual {
        font-size: .75rem;
        color: #64748b;
    }
</style>

<div class="row justify-content-center">
    <div class="col-lg-9">

        <!-- Info orden -->
        <div class="card rec-card mb-4"
             style="border:2px solid #10b981">
            <div class="card-body p-3">
                <div class="row align-items-center">
                    <div class="col">
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-truck text-success" style="font-size:1.4rem"></i>
                            <div>
                                <div class="fw-bold">@Model.NumeroOrden</div>
                                <div class="text-muted small">@Model.Proveedor</div>
                            </div>
                        </div>
                    </div>
                    @if (Model.FechaEntrega.HasValue)
                    {
                        var hoy = DateOnly.FromDateTime(DateTime.Now);
                        var dias = Model.FechaEntrega.Value.DayNumber - hoy.DayNumber;
                        <div class="col-auto">
                            <div class="text-muted small">Fecha entrega</div>
                            <div class="fw-semibold @(dias <= 0 ? "text-danger" : dias <= 2 ? "text-warning" : "")">
                                @Model.FechaEntrega.Value.ToString("dd/MM/yyyy")
                                @if (dias == 0)
                                {
                                    <span class="badge bg-warning ms-1">Hoy</span>
                                }
                                else if (dias < 0)
                                {

                                    <span class="badge bg-danger ms-1">Vencida</span>
                                }
                                else if (dias <= 2)
                                {

                                    <span class="badge bg-warning-subtle text-warning ms-1">@dias día(s)</span>
                                }
                            </div>
                        </div>
                    }
                    <div class="col-auto">
                        <span class="badge bg-info-subtle text-info fs-6 px-3 py-2">
                            @Model.Items.Count producto(s) pendientes
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Formulario recepción -->
        <div class="card rec-card">
            <div class="card-body p-4">
                <h6 class="fw-bold mb-1">
                    <i class="bi bi-box-arrow-in-down me-1 text-success"></i>
                    Ingreso de mercadería
                </h6>
                <p class="text-muted small mb-4">
                    Ingresa las cantidades físicamente recibidas.
                    El stock se actualizará automáticamente.
                </p>

                <form asp-action="Recepcion" asp-controller="Compras"
                      asp-area="almacenero" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="CompraId" value="@Model.CompraId" />
                    <input type="hidden" name="NumeroOrden" value="@Model.NumeroOrden" />
                    <input type="hidden" name="Proveedor" value="@Model.Proveedor" />

                    <table class="table align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Producto</th>
                                <th class="text-center">Pedido</th>
                                <th class="text-center">Ya recibido</th>
                                <th class="text-center">Pendiente</th>
                                <th class="text-center">Stock actual</th>
                                <th class="text-center" style="width:160px">
                                    <span class="text-success fw-bold">
                                        ✓ Recibir ahora
                                    </span>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < Model.Items.Count; i++)
                            {
                                var item = Model.Items[i];
                                <tr class="producto-row">
                                    <input type="hidden"
                                           name="Items[@i].DetalleId"
                                           value="@item.DetalleId" />
                                    <input type="hidden"
                                           name="Items[@i].ProductoId"
                                           value="@item.ProductoId" />
                                    <input type="hidden"
                                           name="Items[@i].NombreProducto"
                                           value="@item.NombreProducto" />
                                    <input type="hidden"
                                           name="Items[@i].Cantidad"
                                           value="@item.Cantidad" />
                                    <input type="hidden"
                                           name="Items[@i].CantidadRecibida"
                                           value="@item.CantidadRecibida" />

                                    <td>
                                        <div class="fw-semibold" style="font-size:.875rem">
                                            @item.NombreProducto
                                        </div>
                                        @if (!string.IsNullOrEmpty(item.Ubicacion))
                                        {
                                            <span class="badge bg-secondary-subtle text-secondary"
                                                  style="font-size:.65rem">
                                                <i class="bi bi-geo-alt"></i> @item.Ubicacion
                                            </span>
                                        }
                                    </td>
                                    <td class="text-center text-muted">
                                        @item.Cantidad
                                    </td>
                                    <td class="text-center">
                                        @if (item.CantidadRecibida > 0)
                                        {
                                            <span class="text-success fw-semibold">
                                                @item.CantidadRecibida
                                            </span>
                                        }
                                        else
                                        {

                                            <span class="text-muted">0</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-warning-subtle text-warning fw-semibold">
                                            @item.CantidadPendiente
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <div class="stock-actual mb-1">
                                            Stock: @item.StockActual
                                        </div>
                                        @if (item.StockActual == 0)
                                        {
                                            <span class="badge bg-danger mb-1"
                                                  style="font-size:.65rem">AGOTADO</span>
                                        }
                                    </td>
                                    <td>
                                        <input type="number"
                                               name="Items[@i].CantidadARecibir"
                                               class="form-control text-center fw-bold"
                                               style="border-color:#10b981; font-size:1rem"
                                               min="0"
                                               max="@item.CantidadPendiente"
                                               step="0.001"
                                               value="@item.CantidadPendiente" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    <div class="alert alert-info py-2 small mt-2">
                        <i class="bi bi-info-circle me-1"></i>
                        Al confirmar: el stock subirá, se registrará en el Kardex
                        y el precio de costo del producto se actualizará.
                    </div>

                    <div class="d-flex gap-2 justify-content-end mt-3">
                        <a asp-area="almacenero" asp-controller="Compras"
                           asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left me-1"></i>Cancelar
                        </a>
                        <button type="button" class="btn btn-outline-success"
                                onclick="ponerCero()">
                            <i class="bi bi-x-circle me-1"></i>Poner todo en 0
                        </button>
                        <button type="submit" class="btn btn-success fw-semibold px-4">
                            <i class="bi bi-box-arrow-in-down me-1"></i>
                            Confirmar recepción
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function ponerCero() {
            document.querySelectorAll('input[name*="CantidadARecibir"]')
                .forEach(i => i.value = 0);
        }
    </script>
}