@model TiendaWeb.Areas.admin.ViewModel.CategoriasIndexViewModel
@{
    Layout = "~/Areas/admin/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Categorías";
}

<style>
    .cat-card {
        border: none;
        border-radius: 14px;
        box-shadow: 0 1px 6px rgba(0,0,0,.07);
    }

    .form-label {
        font-size: .825rem;
        font-weight: 600;
        color: #374151;
    }

    .form-control, .form-select {
        font-size: .875rem;
        background: #f8fafc;
        border-color: #e2e8f0;
    }

        .form-control:focus {
            border-color: #1a56db;
            box-shadow: 0 0 0 3px rgba(26,86,219,.12);
            background: #fff;
        }

    .cat-icon {
        width: 38px;
        height: 38px;
        border-radius: 10px;
        background: #eff6ff;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }
</style>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4 py-2">
        <i class="bi bi-check-circle me-1"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-4 py-2">
        <i class="bi bi-x-circle me-1"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Header -->
<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h5 class="mb-0 fw-bold">Categorías</h5>
        <span class="text-muted small">@Model.Lista.Count categorías registradas</span>
    </div>
    <button class="btn btn-primary fw-semibold"
            data-bs-toggle="modal" data-bs-target="#modalCrear">
        <i class="bi bi-plus-lg me-1"></i> Nueva categoría
    </button>
</div>

<!-- Tabla -->
<div class="card cat-card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Categoría</th>
                        <th>Descripción</th>
                        <th>Estado</th>
                        <th>Creación</th>
                        <th class="text-end pe-4">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model.Lista)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="cat-icon">
                                        @if (!string.IsNullOrEmpty(c.Imagen))
                                        {
                                            <img src="@c.Imagen" alt="@c.Nombre"
                                                 style="width:24px;height:24px;object-fit:cover;border-radius:4px" />
                                        }
                                        else
                                        {
                                            <i class="bi bi-tag text-primary"></i>
                                        }
                                    </div>
                                    <span class="fw-semibold" style="font-size:.875rem">@c.Nombre</span>
                                </div>
                            </td>
                            <td class="small text-muted">@(c.Descripcion ?? "—")</td>
                            <td>
                                @if (c.Estado == true)
                                {
                                    <span class="badge bg-success-subtle text-success">Activa</span>
                                }
                                else
                                {

                                    <span class="badge bg-secondary-subtle text-secondary">Inactiva</span>
                                }
                            </td>
                            <td class="small text-muted">
                                @(c.FechaCreacion?.ToString("dd/MM/yyyy") ?? "—")
                            </td>
                            <td class="text-end pe-4">
                                <button class="btn btn-sm btn-outline-primary me-1"
                                        onclick="cargarEditar(@c.CategoriaId)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <form asp-action="Delete" asp-controller="Categorias"
                                      asp-area="admin" method="post" class="d-inline"
                                      onsubmit="return confirm('¿Desactivar la categoría @c.Nombre?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@c.CategoriaId" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Lista.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-5">
                                <i class="bi bi-tag me-1"></i>No hay categorías registradas
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- ══ MODAL CREAR ══ -->
<div class="modal fade" id="modalCrear" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-bold">
                    <i class="bi bi-plus-lg me-1 text-primary"></i>Nueva categoría
                </h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form asp-action="Create" asp-controller="Categorias"
                      asp-area="admin" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Crear.Nombre" class="form-label"></label>
                            <input asp-for="Crear.Nombre" class="form-control"
                                   placeholder="Ej: Bebidas" />
                            <span asp-validation-for="Crear.Nombre" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Crear.Descripcion" class="form-label"></label>
                            <textarea asp-for="Crear.Descripcion" class="form-control"
                                      rows="2" placeholder="Descripción opcional"></textarea>
                            <span asp-validation-for="Crear.Descripcion" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Crear.Imagen" class="form-label"></label>
                            <input asp-for="Crear.Imagen" class="form-control"
                                   placeholder="https://..." />
                            <span asp-validation-for="Crear.Imagen" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="modal-footer border-0 px-0 pb-0 mt-3">
                        <button type="button" class="btn btn-secondary"
                                data-bs-dismiss="modal">
                            Cancelar
                        </button>
                        <button type="submit" class="btn btn-primary fw-semibold">
                            <i class="bi bi-floppy me-1"></i>Guardar
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- ══ MODAL EDITAR ══ -->
<div class="modal fade" id="modalEditar" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-bold">
                    <i class="bi bi-pencil me-1 text-primary"></i>Editar categoría
                </h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form asp-action="Edit" asp-controller="Categorias"
                      asp-area="admin" method="post" id="formEditar">
                    @Html.AntiForgeryToken()
                    <input asp-for="Editar.CategoriaId" type="hidden" />
                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Editar.Nombre" class="form-label"></label>
                            <input asp-for="Editar.Nombre" class="form-control" />
                            <span asp-validation-for="Editar.Nombre" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Editar.Descripcion" class="form-label"></label>
                            <textarea asp-for="Editar.Descripcion" class="form-control"
                                      rows="2"></textarea>
                        </div>
                        <div class="col-12">
                            <label asp-for="Editar.Imagen" class="form-label"></label>
                            <input asp-for="Editar.Imagen" class="form-control" />
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input asp-for="Editar.Estado" class="form-check-input"
                                       type="checkbox" role="switch" />
                                <label asp-for="Editar.Estado"
                                       class="form-check-label small fw-semibold"></label>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer border-0 px-0 pb-0 mt-3">
                        <button type="button" class="btn btn-secondary"
                                data-bs-dismiss="modal">
                            Cancelar
                        </button>
                        <button type="submit" class="btn btn-primary fw-semibold">
                            <i class="bi bi-floppy me-1"></i>Actualizar
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function cargarEditar(id) {
            fetch(`/admin/Categorias/GetEditar/${id}`)
                .then(r => r.json())
                .then(d => {
                    document.querySelector('#formEditar [name="Editar.CategoriaId"]').value  = d.categoriaId;
                    document.querySelector('#formEditar [name="Editar.Nombre"]').value        = d.nombre;
                    document.querySelector('#formEditar [name="Editar.Descripcion"]').value   = d.descripcion ?? '';
                    document.querySelector('#formEditar [name="Editar.Imagen"]').value        = d.imagen      ?? '';
                    document.querySelector('#formEditar [name="Editar.Estado"]').checked      = d.estado;
                    new bootstrap.Modal('#modalEditar').show();
                });
        }

        @if (TempData["AbrirModalCrear"] != null)
        {
                <text>new bootstrap.Modal('#modalCrear').show();</text>
        }
        @if (TempData["AbrirModalEditar"] != null)
        {
                <text>
                    document.addEventListener('DOMContentLoaded', () =>
                        cargarEditar(@TempData["AbrirModalEditar"]));
                </text>
        }
    </script>
    <partial name="_ValidationScriptsPartial" />
}