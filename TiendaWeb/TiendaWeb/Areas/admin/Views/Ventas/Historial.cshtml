@model TiendaWeb.Areas.admin.ViewModel.VentasHistorialViewModel
@{
    Layout = "~/Areas/admin/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Historial de Ventas";
}

<style>
    .hist-card {
        border: none;
        border-radius: 14px;
        box-shadow: 0 1px 6px rgba(0,0,0,.07);
    }

    .form-control, .form-select {
        font-size: .875rem;
        background: #f8fafc;
        border-color: #e2e8f0;
    }

        .form-control:focus, .form-select:focus {
            border-color: #1a56db;
            box-shadow: 0 0 0 3px rgba(26,86,219,.12);
            background: #fff;
        }
</style>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4 py-2">
        <i class="bi bi-check-circle me-1"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-4 py-2">
        <i class="bi bi-x-circle me-1"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Header + métricas del día -->
<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h5 class="mb-0 fw-bold">Historial de Ventas</h5>
        <span class="text-muted small">
            @Model.TransaccionesDia transacciones ·
            <strong class="text-success">S/ @Model.TotalDia.ToString("N2")</strong>
        </span>
    </div>
    <a asp-action="Index" asp-controller="Ventas" asp-area="admin"
       class="btn btn-primary fw-semibold">
        <i class="bi bi-plus-lg me-1"></i>Nueva venta
    </a>
</div>

<!-- Filtros -->
<form method="get" class="card hist-card p-3 mb-4">
    <div class="row g-2 align-items-end">
        <div class="col-md-3">
            <label class="form-label small fw-semibold">Fecha</label>
            <input type="date" name="fecha" class="form-control"
                   value="@Model.FiltroFecha" />
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-semibold">Estado</label>
            <select name="estado" class="form-select">
                <option value="">Todos</option>
                <option value="COMPLETADA" selected="@(Model.FiltroEstado == "COMPLETADA")">Completada</option>
                <option value="ANULADA" selected="@(Model.FiltroEstado == "ANULADA")">Anulada</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label small fw-semibold">Método pago</label>
            <select name="metodo" class="form-select">
                <option value="">Todos</option>
                @foreach (var m in new[] { "EFECTIVO", "TARJETA", "YAPE", "PLIN", "TRANSFERENCIA" })
                {
                    <option value="@m" selected="@(Model.FiltroMetodo == m)">@m</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">
                <i class="bi bi-search me-1"></i>Filtrar
            </button>
        </div>
        <div class="col-md-2">
            <a asp-action="Historial" asp-area="admin" asp-controller="Ventas"
               class="btn btn-outline-secondary w-100">Limpiar</a>
        </div>
    </div>
</form>

<!-- Tabla -->
<div class="card hist-card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Ticket</th>
                        <th>Cliente</th>
                        <th>Método</th>
                        <th class="text-end">Total</th>
                        <th class="text-end">Pagado</th>
                        <th class="text-end">Vuelto</th>
                        <th>Estado</th>
                        <th>Hora</th>
                        <th>Usuario</th>
                        <th class="text-end pe-4">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var v in Model.Lista)
                    {
                        <tr>
                            <td class="ps-4">
                                <span class="badge bg-light text-dark border">
                                    @v.NumeroTicket
                                </span>
                                <div class="text-muted" style="font-size:.7rem">
                                    @v.TipoComprobante
                                </div>
                            </td>
                            <td class="small">
                                @(v.ClienteNombre ?? "Consumidor Final")
                                @if (!string.IsNullOrEmpty(v.ClienteDocumento))
                                {
                                    <div class="text-muted" style="font-size:.72rem">
                                        @v.ClienteDocumento
                                    </div>
                                }
                            </td>
                            <td>
                                <span class="badge bg-primary-subtle text-primary">
                                    @v.MetodoPago
                                </span>
                            </td>
                            <td class="text-end fw-semibold">
                                S/ @v.Total.ToString("N2")
                            </td>
                            <td class="text-end small">
                                S/ @v.MontoPagado.ToString("N2")
                            </td>
                            <td class="text-end small text-muted">
                                S/ @v.Vuelto.ToString("N2")
                            </td>
                            <td>
                                @if (v.Estado == "COMPLETADA")
                                {
                                    <span class="badge bg-success-subtle text-success">Completada</span>
                                }
                                else if (v.Estado == "ANULADA")
                                {

                                    <span class="badge bg-danger-subtle text-danger">Anulada</span>
                                }
                                else
                                {

                                    <span class="badge bg-warning-subtle text-warning">@v.Estado</span>
                                }
                            </td>
                            <td class="small text-muted">
                                @v.FechaVenta.ToString("HH:mm")
                            </td>
                            <td class="small text-muted">@v.UsuarioNombre</td>
                            <td class="text-end pe-4">
                                <button class="btn btn-sm btn-outline-primary me-1"
                                        onclick="verDetalle(@v.VentaId)">
                                    <i class="bi bi-eye"></i>
                                </button>
                                @if (v.PuedeAnular)
                                {
                                    <button class="btn btn-sm btn-outline-danger"
                                            onclick="confirmarAnulacion(@v.VentaId, '@v.NumeroTicket')">
                                        <i class="bi bi-x-circle"></i>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                    @if (!Model.Lista.Any())
                    {
                        <tr>
                            <td colspan="10" class="text-center text-muted py-5">
                                <i class="bi bi-receipt me-1"></i>Sin ventas en este período
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- ══ MODAL DETALLE ══ -->
<div class="modal fade" id="modalDetalle" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-bold">
                    <i class="bi bi-receipt me-1 text-primary"></i>
                    Detalle de venta — <span id="detTicket"></span>
                </h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="detBody">
                <div class="text-center py-4">
                    <div class="spinner-border text-primary"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ══ MODAL ANULAR ══ -->
<div class="modal fade" id="modalAnular" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-bold text-danger">
                    <i class="bi bi-x-circle me-1"></i>Anular venta
                </h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form asp-action="Anular" asp-controller="Ventas"
                      asp-area="admin" method="post" id="formAnular">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="VentaId" id="anularVentaId" />
                    <p class="text-muted small mb-3">
                        Vas a anular la venta <strong id="anularTicket"></strong>.
                        Esta acción devuelve el stock automáticamente.
                    </p>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">
                            Motivo de anulación *
                        </label>
                        <textarea name="MotivoAnulacion" class="form-control" rows="2"
                                  required placeholder="Describe el motivo..."></textarea>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-secondary flex-grow-1"
                                data-bs-dismiss="modal">
                            Cancelar
                        </button>
                        <button type="submit" class="btn btn-danger fw-semibold flex-grow-1">
                            <i class="bi bi-x-circle me-1"></i>Confirmar anulación
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function verDetalle(id) {
            document.getElementById('detBody').innerHTML =
                '<div class="text-center py-4"><div class="spinner-border text-primary"></div></div>';
            new bootstrap.Modal('#modalDetalle').show();

            const res  = await fetch(`/admin/Ventas/Detalle/${id}`);
            const d    = await res.json();

            document.getElementById('detTicket').textContent = d.numeroTicket;

            const estadoBadge = d.estado === 'COMPLETADA'
                ? '<span class="badge bg-success-subtle text-success">Completada</span>'
                : '<span class="badge bg-danger-subtle text-danger">Anulada</span>';

            const itemsHtml = d.items.map(i => `
                <tr>
                    <td>${i.nombreProducto}</td>
                    <td class="text-center">${i.cantidad}</td>
                    <td class="text-end">S/ ${i.precioUnitario.toFixed(2)}</td>
                    <td class="text-end">${i.descuento > 0 ? '-S/ '+i.descuento.toFixed(2) : '—'}</td>
                    <td class="text-end fw-semibold">S/ ${i.total.toFixed(2)}</td>
                </tr>
            `).join('');

            document.getElementById('detBody').innerHTML = `
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <div class="small text-muted">Comprobante</div>
                        <div class="fw-semibold">${d.tipoComprobante} · ${d.serie}-${String(d.numeroCorrelativo).padStart(8,'0')}</div>
                    </div>
                    <div class="col-md-6">
                        <div class="small text-muted">Cliente</div>
                        <div class="fw-semibold">${d.clienteNombre ?? 'Consumidor Final'}</div>
                        ${d.clienteDocumento ? `<div class="text-muted small">${d.clienteDocumento}</div>` : ''}
                    </div>
                    <div class="col-md-6">
                        <div class="small text-muted">Fecha y hora</div>
                        <div class="fw-semibold">${new Date(d.fechaVenta).toLocaleString('es-PE')}</div>
                    </div>
                    <div class="col-md-6">
                        <div class="small text-muted">Estado</div>
                        ${estadoBadge}
                        ${d.motivoAnulacion ? `<div class="text-danger small mt-1">${d.motivoAnulacion}</div>` : ''}
                    </div>
                </div>
                <table class="table table-sm table-bordered mb-3">
                    <thead class="table-light">
                        <tr>
                            <th>Producto</th>
                            <th class="text-center">Cant.</th>
                            <th class="text-end">Precio</th>
                            <th class="text-end">Desc.</th>
                            <th class="text-end">Total</th>
                        </tr>
                    </thead>
                    <tbody>${itemsHtml}</tbody>
                </table>
                <div class="row justify-content-end">
                    <div class="col-md-5">
                        <div class="d-flex justify-content-between small"><span class="text-muted">Subtotal</span><span>S/ ${d.subtotal.toFixed(2)}</span></div>
                        <div class="d-flex justify-content-between small"><span class="text-muted">IGV</span><span>S/ ${d.igv.toFixed(2)}</span></div>
                        <div class="d-flex justify-content-between small"><span class="text-muted">Descuento</span><span class="text-danger">-S/ ${d.descuento.toFixed(2)}</span></div>
                        <div class="d-flex justify-content-between fw-bold mt-1 border-top pt-1"><span>TOTAL</span><span>S/ ${d.total.toFixed(2)}</span></div>
                        <div class="d-flex justify-content-between small text-muted mt-1"><span>Pagado (${d.metodoPago})</span><span>S/ ${d.montoPagado.toFixed(2)}</span></div>
                        <div class="d-flex justify-content-between small text-muted"><span>Vuelto</span><span>S/ ${d.vuelto.toFixed(2)}</span></div>
                    </div>
                </div>
            `;
        }

        function confirmarAnulacion(id, ticket) {
            document.getElementById('anularVentaId').value       = id;
            document.getElementById('anularTicket').textContent  = ticket;
            new bootstrap.Modal('#modalAnular').show();
        }
    </script>
}