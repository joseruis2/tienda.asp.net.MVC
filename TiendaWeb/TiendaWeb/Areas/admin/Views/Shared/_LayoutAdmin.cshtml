@using Microsoft.AspNetCore.Http
@using System.Security.Claims

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/admin/shared/layout.css" />
    @await RenderSectionAsync("Styles", required: false)

</head>
<body>

    @{
        var usuario = User.FindFirst("Nombres")?.Value ?? User.Identity?.Name ?? "Usuario";
        var rol = User.FindFirst(ClaimTypes.Role)?.Value ?? "";
        var iniciales = usuario.Length > 0 ? usuario[0].ToString().ToUpper() : "U";

        var currentCtrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
        var currentAct = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

        bool IsActive(string ctrl, string? act = null) =>
            currentCtrl.Equals(ctrl, StringComparison.OrdinalIgnoreCase) &&
            (act == null || currentAct.Equals(act, StringComparison.OrdinalIgnoreCase));
    }

    <!-- ══ SIDEBAR ══ -->
    <nav id="sidebar">
        <div class="sidebar-brand">
            <div class="brand-icon"><i class="bi bi-shop"></i></div>
            <span>TiendaWeb</span>
        </div>

        <div class="sidebar-scroll">
            <div class="nav-section">Principal</div>
            <ul class="list-unstyled mb-0">
                <li class="nav-item-admin">
                    <a asp-controller="Dashboard" asp-action="Index"
                       class="@(IsActive("Dashboard") ? "active" : "")">
                        <i class="bi bi-speedometer2"></i> Dashboard
                    </a>
                </li>
            </ul>

            <div class="nav-section mt-2">Operaciones</div>
            <ul class="list-unstyled mb-0">
                <!-- Reemplaza el submenú de Ventas/Caja -->
                <li class="nav-item-admin">
                    <a data-bs-toggle="collapse" href="#menuVentas" role="button"
                       class="@(IsActive("Ventas") || IsActive("Caja") || IsActive("SesionesCaja") ? "active" : "")">
                        <i class="bi bi-cart3"></i> Ventas / Caja
                        <i class="bi bi-chevron-down ms-auto" style="font-size:.7rem"></i>
                    </a>
                    <div class="collapse nav-sub @(IsActive("Ventas") || IsActive("Caja") || IsActive("SesionesCaja") ? "show" : "")" id="menuVentas">
                        <a asp-controller="Ventas" asp-action="Index"
                           class="@(IsActive("Ventas", "Index") ? "active" : "")">Nueva venta</a>
                        <a asp-controller="Ventas" asp-action="Historial"
                           class="@(IsActive("Ventas", "Historial") ? "active" : "")">Historial ventas</a>
                        <a asp-controller="SesionesCaja" asp-action="Index"
                           class="@(IsActive("SesionesCaja") ? "active" : "")">
                            <i class="bi bi-cash-register me-1"></i>Sesiones de caja
                        </a>
                        <a asp-controller="Caja" asp-action="Index"
                           class="@(IsActive("Caja") ? "active" : "")">Gestión de cajas</a>
                    </div>
                </li>

                <li class="nav-item-admin">
                    <a data-bs-toggle="collapse" href="#menuProductos" role="button"
                       class="@(IsActive("Productos") || IsActive("Categorias") ? "active" : "")">
                        <i class="bi bi-box-seam"></i> Productos / Categorías
                        <i class="bi bi-chevron-down ms-auto" style="font-size:.7rem"></i>
                    </a>
                    <div class="collapse nav-sub @(IsActive("Productos") || IsActive("Categorias") ? "show" : "")" id="menuProductos">
                        <a asp-controller="Productos" asp-action="Index" class="@(IsActive("Productos") ? "active" : "")">Productos</a>
                        <a asp-controller="Categorias" asp-action="Index" class="@(IsActive("Categorias") ? "active" : "")">Categorías</a>
                    </div>
                </li>
                <li class="nav-item-admin">
                    <a data-bs-toggle="collapse" href="#menuCompras" role="button"
                       class="@(IsActive("Compras") || IsActive("Proveedores") ? "active" : "")">
                        <i class="bi bi-truck"></i> Compras / Proveedores
                        <i class="bi bi-chevron-down ms-auto" style="font-size:.7rem"></i>
                    </a>
                    <div class="collapse nav-sub @(IsActive("Compras") || IsActive("Proveedores") ? "show" : "")" id="menuCompras">
                        <a asp-controller="Compras" asp-action="Index" class="@(IsActive("Compras") ? "active" : "")">Órdenes de compra</a>
                        <a asp-controller="Proveedores" asp-action="Index" class="@(IsActive("Proveedores") ? "active" : "")">Proveedores</a>
                    </div>
                </li>
                <li class="nav-item-admin">
                    <a asp-controller="Clientes" asp-action="Index"
                       class="@(IsActive("Clientes") ? "active" : "")">
                        <i class="bi bi-people"></i> Clientes
                    </a>
                </li>
            </ul>

            <div class="nav-section mt-2">Administración</div>
            <ul class="list-unstyled mb-0">
                <li class="nav-item-admin">
                    <a asp-controller="Reportes" asp-action="Index"
                       class="@(IsActive("Reportes") ? "active" : "")">
                        <i class="bi bi-bar-chart-line"></i> Reportes
                    </a>
                </li>
                <li class="nav-item-admin">
                    <a asp-controller="Usuarios" asp-action="Index"
                       class="@(IsActive("Usuarios") ? "active" : "")">
                        <i class="bi bi-person-gear"></i> Usuarios
                    </a>
                </li>

                <li class="nav-item-admin">
                    <a asp-controller="Configuracion" asp-action="Index"
                       class="@(IsActive("Configuracion") ? "active" : "")">
                        <i class="bi bi-gear"></i> Configuración
                    </a>
                </li>

                <li class="nav-item-admin">
                    <a asp-controller="Kardex" asp-action="Index"
                       class="@(IsActive("Kardex") ? "active" : "")">
                        <i class="bi bi-journal-text"></i> Kardex
                    </a>
                </li>

                <li class="nav-item-admin">
                    <a asp-controller="Promociones" asp-action="Index"
                       class="@(IsActive("Promociones") ? "active" : "")">
                        <i class="bi bi-journal-text"></i> Promociones
                    </a>
                </li>

                <li class="nav-item-admin">
                    <a asp-controller="Devoluciones" asp-action="Index"
                       class="@(IsActive("Devoluciones") ? "active" : "")">
                        <i class="bi bi-journal-text"></i> Devoluciones
                    </a>
                </li>
            </ul>
        </div>

        <div class="sidebar-footer">
            <div class="user-info">
                <div class="avatar">@iniciales</div>
                <div>
                    <div class="user-name">@usuario</div>
                    <div class="user-rol">@rol</div>
                </div>

                <form asp-controller="Login" asp-action="Logout" asp-area="" method="post" class="ms-auto">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-link p-0 text-secondary" title="Cerrar sesión">
                        <i class="bi bi-box-arrow-right"></i>
                    </button>
                </form>
            </div>
        </div>
    </nav>

    <!-- ══ TOPBAR ══ -->
    <header id="topbar">
        <button class="btn btn-sidebar-toggle btn-sm btn-outline-secondary"
                onclick="document.getElementById('sidebar').classList.toggle('show')">
            <i class="bi bi-list"></i>
        </button>
        <span class="page-title">@(ViewData["Title"] ?? "Dashboard")</span>

        <div class="d-flex align-items-center gap-2">
            <span class="badge bg-success-subtle text-success border border-success-subtle">
                <i class="bi bi-circle-fill me-1" style="font-size:.45rem"></i>En línea
            </span>
            <span class="text-muted small d-none d-md-inline">
                @DateTime.Now.ToString("ddd dd MMM yyyy")
            </span>
        </div>
    </header>

    <!-- ══ CONTENIDO ══ -->
    <main id="main-content">
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>