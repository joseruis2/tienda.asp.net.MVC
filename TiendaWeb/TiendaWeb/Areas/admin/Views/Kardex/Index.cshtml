@model TiendaWeb.Areas.admin.ViewModel.KardexIndexViewModel
@{
    Layout = "~/Areas/admin/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Kardex";
}

<link rel="stylesheet" href="~/css/admin/kardex/index.css" />

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4 py-2">
        <i class="bi bi-check-circle me-1"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-4 py-2">
        <i class="bi bi-x-circle me-1"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Header -->
<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h5 class="mb-0 fw-bold">Kardex — Movimientos de inventario</h5>
        <span class="text-muted small">
            Últimos @Model.Lista.Count movimientos
        </span>
    </div>
    <button class="btn btn-primary fw-semibold"
            data-bs-toggle="modal" data-bs-target="#modalAjuste">
        <i class="bi bi-arrow-left-right me-1"></i>Ajuste manual
    </button>
</div>

<!-- Filtros -->
<form method="get" class="card kdx-card p-3 mb-4">
    <div class="row g-2 align-items-end">
        <div class="col-md-3">
            <label class="form-label small fw-semibold">Producto</label>
            <select name="productoId" class="form-select">
                <option value="">Todos</option>
                @foreach (var p in Model.Productos)
                {
                    <option value="@p.Id"
                            selected="@(Model.FiltroProductoId == p.Id.ToString())">
                        @p.Nombre
                    </option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-semibold">Tipo</label>
            <select name="tipo" class="form-select">
                <option value="">Todos</option>
                <option value="ENTRADA" selected="@(Model.FiltroTipo=="ENTRADA")">ENTRADA</option>
                <option value="SALIDA"  selected="@(Model.FiltroTipo=="SALIDA")">SALIDA</option>
                <option value="AJUSTE"  selected="@(Model.FiltroTipo=="AJUSTE")">AJUSTE</option>
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-semibold">Origen</label>
            <select name="origen" class="form-select">
                <option value="">Todos</option>
                @foreach (var o in new[]{"COMPRA","VENTA","AJUSTE_MANUAL","DEVOLUCION","INICIAL"})
                {
                    <option value="@o" selected="@(Model.FiltroOrigen==o)">@o</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-semibold">Fecha</label>
            <input type="date" name="fecha" class="form-control"
                   value="@Model.FiltroFecha" />
        </div>
        <div class="col-md-1">
            <button type="submit" class="btn btn-primary w-100">
                <i class="bi bi-search"></i>
            </button>
        </div>
        <div class="col-md-2">
            <a asp-action="Index" asp-area="admin" asp-controller="Kardex"
               class="btn btn-outline-secondary w-100">Limpiar</a>
        </div>
    </div>
</form>

<!-- Tabla -->
<div class="card kdx-card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Producto</th>
                        <th>Tipo</th>
                        <th>Origen</th>
                        <th class="text-end text-success">Entrada</th>
                        <th class="text-end text-danger">Salida</th>
                        <th class="text-end">Ant.</th>
                        <th class="text-end">Resultado</th>
                        <th>Costo</th>
                        <th>Descripción</th>
                        <th>Usuario</th>
                        <th>Fecha</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var k in Model.Lista)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-semibold" style="font-size:.875rem">
                                    @k.ProductoNombre
                                </div>
                                <div class="text-muted" style="font-size:.72rem">
                                    @k.ProductoCodigo
                                </div>
                            </td>
                            <td>
                                @{
                                    var tipoClass = k.Tipo switch {
                                        "ENTRADA" => "tipo-entrada",
                                        "SALIDA"  => "tipo-salida",
                                        _         => "tipo-ajuste"
                                    };
                                    var tipoIcon = k.Tipo switch {
                                        "ENTRADA" => "bi-arrow-up-circle-fill",
                                        "SALIDA"  => "bi-arrow-down-circle-fill",
                                        _         => "bi-arrow-left-right"
                                    };
                                }
                                <span class="@tipoClass">
                                    <i class="bi @tipoIcon me-1"></i>@k.Tipo
                                </span>
                            </td>
                            <td>
                                @{
                                    var origenClass = k.Origen switch {
                                        "COMPRA"       => "bg-primary-subtle text-primary",
                                        "VENTA"        => "bg-success-subtle text-success",
                                        "AJUSTE_MANUAL"=> "bg-warning-subtle text-warning",
                                        "DEVOLUCION"   => "bg-info-subtle text-info",
                                        "INICIAL"      => "bg-secondary-subtle text-secondary",
                                        _              => "bg-light text-dark"
                                    };
                                }
                                <span class="badge origen-badge @origenClass">
                                    @k.Origen
                                </span>
                                @if (k.ReferenciaId.HasValue)
                                {
                                    <div class="text-muted" style="font-size:.68rem">
                                        @k.ReferenciaTipo #@k.ReferenciaId
                                    </div>
                                }
                            </td>
                            <td class="text-end">
                                @if (k.Entrada > 0)
                                {
                                    <span class="fw-bold text-success">+@k.Entrada.ToString("N3")</span>
                                }
                                else { <span class="text-muted">—</span> }
                            </td>
                            <td class="text-end">
                                @if (k.Salida > 0)
                                {
                                    <span class="fw-bold text-danger">-@k.Salida.ToString("N3")</span>
                                }
                                else { <span class="text-muted">—</span> }
                            </td>
                            <td class="text-end text-muted small">
                                @k.StockAnterior.ToString("N3")
                            </td>
                            <td class="text-end">
                                <span class="fw-bold @(k.StockResultante <= 0 ? "text-danger" : "")">
                                    @k.StockResultante.ToString("N3")
                                </span>
                            </td>
                            <td class="small text-muted">
                                @(k.CostoUnitario > 0 ? $"S/ {k.CostoUnitario:N2}" : "—")
                            </td>
                            <td class="small text-muted" style="max-width:160px">
                                @k.Descripcion
                            </td>
                            <td class="small text-muted">@k.UsuarioNombre</td>
                            <td class="small text-muted" style="white-space:nowrap">
                                @k.FechaMovimiento.ToString("dd/MM/yy HH:mm")
                            </td>
                        </tr>
                    }
                    @if (!Model.Lista.Any())
                    {
                        <tr>
                            <td colspan="11" class="text-center text-muted py-5">
                                <i class="bi bi-inbox me-1"></i>
                                Sin movimientos registrados
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- ══ MODAL AJUSTE MANUAL ══ -->
<div class="modal fade" id="modalAjuste" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-bold">
                    <i class="bi bi-arrow-left-right me-1 text-primary"></i>
                    Ajuste manual de inventario
                </h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form asp-action="Ajuste" asp-controller="Kardex"
                      asp-area="admin" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Ajuste.ProductoId" class="form-label"></label>
                            <select asp-for="Ajuste.ProductoId" class="form-select">
                                <option value="">— Seleccionar producto —</option>
                                @foreach (var p in Model.Productos)
                                {
                                    <option value="@p.Id">@p.Nombre</option>
                                }
                            </select>
                            <span asp-validation-for="Ajuste.ProductoId"
                                  class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Ajuste.Tipo" class="form-label"></label>
                            <div class="d-flex gap-2">
                                @foreach (var t in new[] {
                                    ("ENTRADA", "bi-arrow-up-circle",   "text-success", "Entrada"),
                                    ("SALIDA",  "bi-arrow-down-circle", "text-danger",  "Salida"),
                                    ("AJUSTE",  "bi-arrow-left-right",  "text-primary", "Ajuste stock")
                                    })
                                {
                                    <div class="form-check flex-grow-1 border rounded p-2 text-center"
                                         style="cursor:pointer">
                                        @if (t.Item1 == "ENTRADA")
                                        {
                                            <input class="form-check-input" type="radio"
                                                   asp-for="Ajuste.Tipo"
                                                   value="@t.Item1"
                                                   id="tipo@(t.Item1)"
                                                   checked />
                                        }
                                        else
                                        {
                                            <input class="form-check-input" type="radio"
                                                   asp-for="Ajuste.Tipo"
                                                   value="@t.Item1"
                                                   id="tipo@(t.Item1)" />
                                        }
                                        <label class="form-check-label d-block"
                                               for="tipo@(t.Item1)" style="cursor:pointer">
                                            <i class="bi @t.Item2 @t.Item3 d-block"
                                               style="font-size:1.3rem"></i>
                                            <span class="small fw-semibold">@t.Item4</span>
                                        </label>
                                    </div>
                                }
                            </div>
                            <div class="form-text">
                                <strong>Ajuste stock</strong>: establece la cantidad exacta
                                (inventario físico)
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Ajuste.Cantidad" class="form-label"></label>
                            <input asp-for="Ajuste.Cantidad" type="number" class="form-control"
                                   min="0.001" step="0.001" placeholder="0.000" />
                            <span asp-validation-for="Ajuste.Cantidad"
                                  class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Ajuste.CostoUnitario" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text">S/</span>
                                <input asp-for="Ajuste.CostoUnitario" type="number"
                                       class="form-control" min="0" step="0.01" />
                            </div>
                        </div>
                        <div class="col-12">
                            <label asp-for="Ajuste.Descripcion" class="form-label"></label>
                            <textarea asp-for="Ajuste.Descripcion" class="form-control"
                                      rows="2" placeholder="Motivo del ajuste..."></textarea>
                            <span asp-validation-for="Ajuste.Descripcion"
                                  class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="modal-footer border-0 px-0 pb-0 mt-3">
                        <button type="button" class="btn btn-secondary"
                                data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-primary fw-semibold">
                            <i class="bi bi-floppy me-1"></i>Registrar ajuste
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    @if (TempData["AbrirModalAjuste"] != null)
    {
        <text>new bootstrap.Modal('#modalAjuste').show();</text>
    }
</script>
<partial name="_ValidationScriptsPartial" />
}