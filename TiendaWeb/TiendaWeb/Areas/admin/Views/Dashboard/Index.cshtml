@model TiendaWeb.Areas.admin.ViewModel.DashboardViewModel
@{
    Layout = "~/Areas/admin/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Dashboard";
}

<style>
    .metric-card {
        border: none;
        border-radius: 14px;
        box-shadow: 0 1px 6px rgba(0,0,0,.07);
    }

    .metric-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.35rem;
    }

    .metric-value {
        font-size: 1.6rem;
        font-weight: 800;
        line-height: 1;
    }

    .metric-label {
        font-size: .78rem;
        color: #64748b;
    }

    .table-card {
        border: none;
        border-radius: 14px;
        box-shadow: 0 1px 6px rgba(0,0,0,.07);
    }
</style>

<!-- ── Tarjetas métricas ── -->
<div class="row g-3 mb-4">

    <!-- Ventas del día -->
    <div class="col-6 col-md-4 col-xl-2">
        <div class="card metric-card p-3 h-100">
            <div class="metric-icon bg-primary-subtle text-primary mb-2">
                <i class="bi bi-cash-stack"></i>
            </div>
            <div class="metric-value text-primary">S/ @Model.VentasHoy.ToString("N2")</div>
            <div class="metric-label mt-1">Ventas hoy</div>
            <div class="mt-1" style="font-size:.75rem; color:#94a3b8">
                @Model.TransaccionesHoy transacciones
            </div>
        </div>
    </div>

    <!-- Stock bajo -->
    <div class="col-6 col-md-4 col-xl-2">
        <div class="card metric-card p-3 h-100">
            <div class="metric-icon bg-warning-subtle text-warning mb-2">
                <i class="bi bi-exclamation-triangle"></i>
            </div>
            <div class="metric-value text-warning">@Model.ProductosStockBajo</div>
            <div class="metric-label mt-1">Stock bajo</div>
            <div class="mt-1" style="font-size:.75rem; color:#94a3b8">productos críticos</div>
        </div>
    </div>

    <!-- Clientes nuevos -->
    <div class="col-6 col-md-4 col-xl-2">
        <div class="card metric-card p-3 h-100">
            <div class="metric-icon bg-success-subtle text-success mb-2">
                <i class="bi bi-person-plus"></i>
            </div>
            <div class="metric-value text-success">@Model.ClientesNuevosHoy</div>
            <div class="metric-label mt-1">Clientes nuevos</div>
            <div class="mt-1" style="font-size:.75rem; color:#94a3b8">registrados hoy</div>
        </div>
    </div>

    <!-- Compras pendientes -->
    <div class="col-6 col-md-4 col-xl-2">
        <div class="card metric-card p-3 h-100">
            <div class="metric-icon bg-info-subtle text-info mb-2">
                <i class="bi bi-truck"></i>
            </div>
            <div class="metric-value text-info">@Model.ComprasPendientes</div>
            <div class="metric-label mt-1">Compras pendientes</div>
            <div class="mt-1" style="font-size:.75rem; color:#94a3b8">por recibir</div>
        </div>
    </div>

    <!-- Estado caja -->
    <div class="col-6 col-md-4 col-xl-2">
        @{
            bool cajaAbierta = Model.EstadoCaja == "ABIERTA";
        }
        <div class="card metric-card p-3 h-100">
            <div class="metric-icon @(cajaAbierta ? "bg-success-subtle text-success" : "bg-secondary-subtle text-secondary") mb-2">
                <i class="bi bi-cash-register"></i>
            </div>
            <div class="metric-value @(cajaAbierta ? "text-success" : "text-secondary")">
                @(cajaAbierta ? "Abierta" : "Cerrada")
            </div>
            <div class="metric-label mt-1">Estado de caja</div>
            @if (cajaAbierta)
            {
                <div class="mt-1" style="font-size:.75rem; color:#94a3b8">
                    S/ @Model.MontoCaja.ToString("N2") apertura
                </div>
            }
        </div>
    </div>
</div>

<!-- ── Últimas ventas ── -->
<div class="card table-card">
    <div class="card-body">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <h6 class="mb-0 fw-bold">Últimas ventas</h6>
            <a asp-controller="Ventas" asp-action="Historial"
               class="btn btn-sm btn-outline-primary">Ver todas</a>
        </div>

        <div class="table-responsive">
            <table class="table table-hover table-sm align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Ticket</th>
                        <th>Cliente</th>
                        <th>Método</th>
                        <th class="text-end">Total</th>
                        <th>Estado</th>
                        <th>Hora</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var v in Model.UltimasVentas)
                    {
                        <tr>
                            <td><span class="badge bg-light text-dark border">@v.NumeroTicket</span></td>
                            <td>@v.ClienteNombre</td>
                            <td>
                                <span class="badge bg-primary-subtle text-primary">@v.MetodoPago</span>
                            </td>
                            <td class="text-end fw-semibold">S/ @v.Total.ToString("N2")</td>
                            <td>
                                @if (v.Estado == "COMPLETADA")
                                {
                                    <span class="badge bg-success-subtle text-success">Completada</span>
                                }
                                else if (v.Estado == "ANULADA")
                                {
                                    <span class="badge bg-danger-subtle text-danger">Anulada</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning-subtle text-warning">@v.Estado</span>
                                }
                            </td>
                            <td class="text-muted small">@v.FechaVenta?.ToString("HH:mm")</td>
                        </tr>
                    }
                    @if (!Model.UltimasVentas.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                <i class="bi bi-inbox me-1"></i>Sin ventas registradas hoy
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>