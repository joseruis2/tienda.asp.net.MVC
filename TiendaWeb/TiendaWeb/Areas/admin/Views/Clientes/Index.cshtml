@model TiendaWeb.Areas.admin.ViewModel.ClientesIndexViewModel
@{
    Layout = "~/Areas/admin/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Clientes";
}

<link rel="stylesheet" href="~/css/admin/clientes/index.css" />

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4 py-2">
        <i class="bi bi-check-circle me-1"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-4 py-2">
        <i class="bi bi-x-circle me-1"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Header -->
<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h5 class="mb-0 fw-bold">Clientes</h5>
        <span class="text-muted small">
            @Model.Lista.Count clientes registrados
        </span>
    </div>
    <button class="btn btn-primary fw-semibold"
            data-bs-toggle="modal" data-bs-target="#modalCrear">
        <i class="bi bi-person-plus me-1"></i> Nuevo cliente
    </button>
</div>

<!-- Tabla -->
<div class="card cli-card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Cliente</th>
                        <th>Documento</th>
                        <th>Contacto</th>
                        <th>Puntos</th>
                        <th>Total compras</th>
                        <th>Estado</th>
                        <th class="text-end pe-4">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model.Lista)
                    {
                        var inicial = c.NombreCompleto.Length > 0
                            ? c.NombreCompleto[0].ToString().ToUpper() : "C";
                        var color = c.EsEmpresa ? "#7c3aed" : "#1a56db";
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="avatar-cli" style="background:@color">
                                        @inicial
                                    </div>
                                    <div>
                                        <div class="fw-semibold" style="font-size:.875rem">
                                            @c.NombreCompleto
                                        </div>
                                        @if (!string.IsNullOrEmpty(c.Codigo))
                                        {
                                            <div class="text-muted" style="font-size:.72rem">
                                                Cód: @c.Codigo
                                            </div>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-primary-subtle text-primary me-1">
                                    @c.TipoDocumento
                                </span>
                                <span class="small">@(c.NumeroDocumento ?? "—")</span>
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(c.Telefono))
                                {
                                    <div class="small"><i class="bi bi-telephone me-1 text-muted"></i>@c.Telefono</div>
                                }
                                @if (!string.IsNullOrEmpty(c.Email))
                                {
                                    <div class="small text-muted">@c.Email</div>
                                }
                                @if (string.IsNullOrEmpty(c.Telefono) && string.IsNullOrEmpty(c.Email))
                                {
                                    <span class="text-muted small">—</span>
                                }
                            </td>
                            <td>
                                <span class="badge bg-warning-subtle text-warning">
                                    <i class="bi bi-star-fill me-1" style="font-size:.65rem"></i>
                                    @(c.PuntosAcumulados ?? 0)
                                </span>
                            </td>
                            <td class="fw-semibold small text-success">
                                S/ @(c.TotalCompras?.ToString("N2") ?? "0.00")
                            </td>
                            <td>
                                @if (c.Estado == true)
                                {
                                    <span class="badge bg-success-subtle text-success">Activo</span>
                                }
                                else
                                {

                                    <span class="badge bg-secondary-subtle text-secondary">Inactivo</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <button class="btn btn-sm btn-outline-primary me-1"
                                        onclick="cargarEditar(@c.ClienteId)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <form asp-action="Delete" asp-controller="Clientes"
                                      asp-area="admin" method="post" class="d-inline"
                                      onsubmit="return confirm('¿Desactivar cliente?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@c.ClienteId" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-person-x"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Lista.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-5">
                                <i class="bi bi-people me-1"></i>No hay clientes registrados
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- ══ MODAL CREAR ══ -->
<div class="modal fade" id="modalCrear" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-bold">
                    <i class="bi bi-person-plus me-1 text-primary"></i>Nuevo cliente
                </h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form asp-action="Create" asp-controller="Clientes"
                      asp-area="admin" method="post" id="formCrear">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">

                        <div class="col-12">
                            <div class="section-divider">Identificación</div>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Crear.TipoDocumento" class="form-label"></label>
                            <select asp-for="Crear.TipoDocumento" class="form-select"
                                    onchange="toggleCampos(this.value, 'Crear')">
                                <option value="DNI">DNI</option>
                                <option value="RUC">RUC</option>
                                <option value="CE">CE</option>
                                <option value="PASAPORTE">PASAPORTE</option>
                                <option value="NINGUNO">NINGUNO</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Crear.NumeroDocumento" class="form-label"></label>
                            <input asp-for="Crear.NumeroDocumento" class="form-control"
                                   placeholder="Número de documento" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Crear.Codigo" class="form-label"></label>
                            <input asp-for="Crear.Codigo" class="form-control"
                                   placeholder="CLI001 (opcional)" />
                        </div>

                        <!-- Persona natural -->
                        <div id="Crear-natural">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label asp-for="Crear.Nombres" class="form-label"></label>
                                    <input asp-for="Crear.Nombres" class="form-control"
                                           placeholder="Juan" />
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="Crear.Apellidos" class="form-label"></label>
                                    <input asp-for="Crear.Apellidos" class="form-control"
                                           placeholder="Pérez" />
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="Crear.FechaNacimiento" class="form-label"></label>
                                    <input asp-for="Crear.FechaNacimiento" type="date"
                                           class="form-control" />
                                </div>
                            </div>
                        </div>

                        <!-- Empresa (RUC) -->
                        <div id="Crear-empresa" style="display:none" class="col-12">
                            <label asp-for="Crear.RazonSocial" class="form-label"></label>
                            <input asp-for="Crear.RazonSocial" class="form-control"
                                   placeholder="Empresa SAC" />
                        </div>

                        <div class="col-12">
                            <div class="section-divider">Contacto</div>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Crear.Telefono" class="form-label"></label>
                            <input asp-for="Crear.Telefono" class="form-control"
                                   placeholder="999999999" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Crear.Email" class="form-label"></label>
                            <input asp-for="Crear.Email" type="email" class="form-control"
                                   placeholder="cliente@email.com" />
                            <span asp-validation-for="Crear.Email" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Crear.Direccion" class="form-label"></label>
                            <input asp-for="Crear.Direccion" class="form-control"
                                   placeholder="Av. Principal 123" />
                        </div>
                    </div>
                    <div class="modal-footer border-0 px-0 pb-0 mt-3">
                        <button type="button" class="btn btn-secondary"
                                data-bs-dismiss="modal">
                            Cancelar
                        </button>
                        <button type="submit" class="btn btn-primary fw-semibold">
                            <i class="bi bi-floppy me-1"></i>Guardar
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- ══ MODAL EDITAR ══ -->
<div class="modal fade" id="modalEditar" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-bold">
                    <i class="bi bi-pencil me-1 text-primary"></i>Editar cliente
                </h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form asp-action="Edit" asp-controller="Clientes"
                      asp-area="admin" method="post" id="formEditar">
                    @Html.AntiForgeryToken()
                    <input asp-for="Editar.ClienteId" type="hidden" />
                    <div class="row g-3">

                        <div class="col-12">
                            <div class="section-divider">Identificación</div>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Editar.TipoDocumento" class="form-label"></label>
                            <select asp-for="Editar.TipoDocumento" class="form-select"
                                    onchange="toggleCampos(this.value, 'Editar')">
                                <option value="DNI">DNI</option>
                                <option value="RUC">RUC</option>
                                <option value="CE">CE</option>
                                <option value="PASAPORTE">PASAPORTE</option>
                                <option value="NINGUNO">NINGUNO</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Editar.NumeroDocumento" class="form-label"></label>
                            <input asp-for="Editar.NumeroDocumento" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Editar.Codigo" class="form-label"></label>
                            <input asp-for="Editar.Codigo" class="form-control" />
                        </div>

                        <!-- Persona natural -->
                        <div id="Editar-natural">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label asp-for="Editar.Nombres" class="form-label"></label>
                                    <input asp-for="Editar.Nombres" class="form-control" />
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="Editar.Apellidos" class="form-label"></label>
                                    <input asp-for="Editar.Apellidos" class="form-control" />
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="Editar.FechaNacimiento" class="form-label"></label>
                                    <input asp-for="Editar.FechaNacimiento" type="date"
                                           class="form-control" />
                                </div>
                            </div>
                        </div>

                        <!-- Empresa -->
                        <div id="Editar-empresa" style="display:none" class="col-12">
                            <label asp-for="Editar.RazonSocial" class="form-label"></label>
                            <input asp-for="Editar.RazonSocial" class="form-control" />
                        </div>

                        <div class="col-12">
                            <div class="section-divider">Contacto</div>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Editar.Telefono" class="form-label"></label>
                            <input asp-for="Editar.Telefono" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Editar.Email" class="form-label"></label>
                            <input asp-for="Editar.Email" type="email" class="form-control" />
                            <span asp-validation-for="Editar.Email" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Editar.Direccion" class="form-label"></label>
                            <input asp-for="Editar.Direccion" class="form-control" />
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input asp-for="Editar.Estado" class="form-check-input"
                                       type="checkbox" role="switch" />
                                <label asp-for="Editar.Estado"
                                       class="form-check-label small fw-semibold"></label>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer border-0 px-0 pb-0 mt-3">
                        <button type="button" class="btn btn-secondary"
                                data-bs-dismiss="modal">
                            Cancelar
                        </button>
                        <button type="submit" class="btn btn-primary fw-semibold">
                            <i class="bi bi-floppy me-1"></i>Actualizar
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Mostrar/ocultar campos según tipo documento
        function toggleCampos(tipo, prefijo) {
            const natural  = document.getElementById(`${prefijo}-natural`);
            const empresa  = document.getElementById(`${prefijo}-empresa`);
            if (tipo === 'RUC') {
                natural.style.display = 'none';
                empresa.style.display = 'block';
            } else {
                natural.style.display = 'block';
                empresa.style.display = 'none';
            }
        }

        // Cargar datos en modal editar
        function cargarEditar(id) {
            fetch(`/admin/Clientes/GetEditar/${id}`)
                .then(r => r.json())
                .then(d => {
                    const f = '#formEditar';
                    document.querySelector(`${f} [name="Editar.ClienteId"]`).value       = d.clienteId;
                    document.querySelector(`${f} [name="Editar.Codigo"]`).value          = d.codigo          ?? '';
                    document.querySelector(`${f} [name="Editar.TipoDocumento"]`).value   = d.tipoDocumento;
                    document.querySelector(`${f} [name="Editar.NumeroDocumento"]`).value = d.numeroDocumento  ?? '';
                    document.querySelector(`${f} [name="Editar.Nombres"]`).value         = d.nombres          ?? '';
                    document.querySelector(`${f} [name="Editar.Apellidos"]`).value       = d.apellidos        ?? '';
                    document.querySelector(`${f} [name="Editar.RazonSocial"]`).value     = d.razonSocial      ?? '';
                    document.querySelector(`${f} [name="Editar.Direccion"]`).value       = d.direccion        ?? '';
                    document.querySelector(`${f} [name="Editar.Telefono"]`).value        = d.telefono         ?? '';
                    document.querySelector(`${f} [name="Editar.Email"]`).value           = d.email            ?? '';
                    document.querySelector(`${f} [name="Editar.FechaNacimiento"]`).value = d.fechaNacimiento
                        ? d.fechaNacimiento.substring(0, 10) : '';
                    document.querySelector(`${f} [name="Editar.Estado"]`).checked        = d.estado;

                    // Toggle campos según tipo
                    toggleCampos(d.tipoDocumento, 'Editar');
                    new bootstrap.Modal('#modalEditar').show();
                });
        }

        @if (TempData["AbrirModalCrear"] != null)
        {
                <text>new bootstrap.Modal('#modalCrear').show();</text>
        }
        @if (TempData["AbrirModalEditar"] != null)
        {
                <text>
                    document.addEventListener('DOMContentLoaded', () =>
                        cargarEditar(@TempData["AbrirModalEditar"]));
                </text>
        }
    </script>
    <partial name="_ValidationScriptsPartial" />
}