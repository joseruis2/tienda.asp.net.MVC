@model TiendaWeb.Infrastructure.ViewModels.LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Iniciar Sesión</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
            body { background: linear-gradient(135deg,#1a56db,#1e3a8a); min-height:100vh; display:flex; align-items:center; justify-content:center; font-family:'Segoe UI',sans-serif; }
            .card { border-radius:16px; border:none; box-shadow:0 4px 24px rgba(0,0,0,.12); max-width:420px; width:100%; padding:2.5rem 2rem; }
            .brand { width:56px; height:56px; background:#1a56db; border-radius:14px; display:flex; align-items:center; justify-content:center; margin:0 auto 1.25rem; }
            .brand i { font-size:1.75rem; color:#fff; }
            .form-label { font-size:.875rem; font-weight:600; }
            .input-group-text { background:#f8fafc; border-right:none; }
            .form-control { border-left:none; background:#f8fafc; }
            .form-control:focus { border-color:#1a56db; box-shadow:0 0 0 3px rgba(26,86,219,.15); background:#fff; }
            .input-group:focus-within .input-group-text { border-color:#1a56db; background:#fff; }
            .toggle-eye { background:#f8fafc; border-left:none; }
    </style>
</head>
<body>
    <div class="card bg-white">
        <div class="brand"><i class="bi bi-shop"></i></div>
        <h5 class="text-center fw-bold mb-1">Bienvenido</h5>
        <p class="text-center text-muted mb-4" style="font-size:.85rem">Ingresa tus credenciales para continuar</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger py-2 px-3" style="font-size:.875rem">
                <asp-validation-summary model-only="true"></asp-validation-summary>
            </div>
        }

        <form asp-action="Index" asp-controller="Login" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label asp-for="Username" class="form-label"></label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-person"></i></span>
                    <input asp-for="Username" class="form-control" placeholder="Nombre de usuario" autocomplete="username" />
                </div>
                <span asp-validation-for="Username" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-lock"></i></span>
                    <input asp-for="Password" id="pwd" class="form-control" placeholder="Contraseña" autocomplete="current-password" />
                    <button type="button" class="btn toggle-eye border" onclick="togglePwd()">
                        <i class="bi bi-eye" id="eyeIcon"></i>
                    </button>
                </div>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-4 form-check">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label" style="font-size:.875rem">Recordar mi sesión (7 días)</label>
            </div>

            <button type="submit" class="btn btn-primary w-100 fw-semibold">
                <i class="bi bi-box-arrow-in-right me-1"></i> Ingresar
            </button>
        </form>

        <hr class="my-3" style="border-color:#e5e7eb">
        <p class="text-center mb-0" style="font-size:.85rem; color:#6b7280">
            ¿No tienes cuenta?
            <a asp-controller="Register" asp-action="Index" style="color:#1a56db; font-weight:600; text-decoration:none;">
                Registrar usuario
            </a>
        </p>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function togglePwd() {
        var i = document.getElementById('pwd');
        var e = document.getElementById('eyeIcon');
        if (i.type === 'password') { i.type = 'text'; e.classList.replace('bi-eye','bi-eye-slash'); }
        else { i.type = 'password'; e.classList.replace('bi-eye-slash','bi-eye'); }
        }
    </script>
</body>
</html>